<Window x:Class="ASD4G.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:services="clr-namespace:ASD4G.Services"
        mc:Ignorable="d"
        Title="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[App.Title]}"
        Width="1120"
        Height="700"
        MinWidth="1040"
        MinHeight="640"
        Icon="Assets/app.ico"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="FluentNavigationTabItemStyle"
               TargetType="TabItem">
            <Setter Property="Width"
                    Value="220" />
            <Setter Property="MinHeight"
                    Value="56" />
            <Setter Property="Padding"
                    Value="18,14" />
            <Setter Property="FontSize"
                    Value="15" />
            <Setter Property="FontWeight"
                    Value="Normal" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Margin="0,0,0,8"
                                Padding="{TemplateBinding Padding}"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="SelectionIndicator"
                                        Grid.Column="0"
                                        Width="3"
                                        Margin="0,4,12,4"
                                        HorizontalAlignment="Left"
                                        Background="Transparent"
                                        CornerRadius="2" />
                                <ContentPresenter Grid.Column="1"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  ContentSource="Header" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="TabBorder"
                                        Property="Background"
                                        Value="#F4F4F4" />
                            </Trigger>
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter TargetName="TabBorder"
                                        Property="Background"
                                        Value="#FFFFFF" />
                                <Setter TargetName="TabBorder"
                                        Property="BorderBrush"
                                        Value="#E0E0E0" />
                                <Setter TargetName="SelectionIndicator"
                                        Property="Background"
                                        Value="#0F6CBD" />
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter TargetName="TabBorder"
                                        Property="Opacity"
                                        Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarTabControlStyle"
               TargetType="TabControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="264" />
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Margin="0,0,6,0"
                                    Padding="10"
                                    Background="#F7F7F7"
                                    BorderBrush="#E6E6E6"
                                    BorderThickness="1"
                                    CornerRadius="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Margin="8,8,8,14"
                                               Opacity="0.72"
                                               Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[App.Name]}" />

                                    <TabPanel Grid.Row="1"
                                              Margin="0,0,0,6"
                                              IsItemsHost="True"
                                              KeyboardNavigation.TabIndex="1" />

                                    <Border Grid.Row="2"
                                            Margin="4,12,4,4"
                                            Padding="16"
                                            Background="#FFFFFF"
                                            BorderBrush="#E2E2E2"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                        <StackPanel>
                                            <TextBlock FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Sidebar.QuickView]}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       FontSize="12"
                                                       Opacity="0.68"
                                                       Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Overview.CurrentSetup]}" />
                                            <Separator Margin="0,12,0,8" />

                                            <StackPanel Margin="0,4,0,0">
                                                <TextBlock FontSize="12"
                                                           Opacity="0.68"
                                                           Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Operation.MonitorState]}" />
                                                <TextBlock Margin="0,2,0,0"
                                                           Text="{Binding MonitorStateText}" />
                                            </StackPanel>

                                            <Separator Margin="0,12,0,8" />

                                            <StackPanel Margin="0,4,0,0">
                                                <TextBlock FontSize="12"
                                                           Opacity="0.68"
                                                           Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Operation.TargetResolution]}" />
                                                <TextBlock Margin="0,2,0,0"
                                                           Text="{Binding TargetResolutionText}" />
                                            </StackPanel>

                                            <Separator Margin="0,12,0,8" />

                                            <StackPanel Margin="0,4,0,0">
                                                <TextBlock FontSize="12"
                                                           Opacity="0.68"
                                                           Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Overview.TargetPrograms]}" />
                                                <TextBlock Margin="0,2,0,0"
                                                           Text="{Binding TargetProgramsCountValueText}" />
                                            </StackPanel>

                                            <Separator Margin="0,12,0,8" />

                                            <StackPanel Margin="0,4,0,0">
                                                <TextBlock FontSize="12"
                                                           Opacity="0.68"
                                                           Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings.AutoStartTitle]}" />
                                                <TextBlock Margin="0,2,0,0"
                                                           Text="{Binding AutoStartStateText}" />
                                            </StackPanel>

                                            <Separator Margin="0,12,0,8" />

                                            <StackPanel Margin="0,4,0,0">
                                                <TextBlock FontSize="12"
                                                           Opacity="0.68"
                                                           Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings.LanguageTitle]}" />
                                                <TextBlock Margin="0,2,0,0"
                                                           Text="{Binding SelectedLanguageText}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <Separator Grid.Column="1"
                                       Margin="0,12,8,12" />

                            <ContentPresenter Grid.Column="2"
                                              Margin="8,0,0,0"
                                              ContentSource="SelectedContent" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PageTitleStyle"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="30" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="VerticalAlignment"
                    Value="Center" />
        </Style>

        <Style x:Key="CaptionTextStyle"
               TargetType="TextBlock">
            <Setter Property="Opacity"
                    Value="0.72" />
        </Style>

        <Style x:Key="StatePrimaryValueTextStyle"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="24" />
            <Setter Property="FontWeight"
                    Value="Normal" />
        </Style>

        <Style x:Key="StateSecondaryValueTextStyle"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="18" />
            <Setter Property="FontWeight"
                    Value="Normal" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <TabControl Style="{StaticResource SidebarTabControlStyle}"
                    ItemContainerStyle="{StaticResource FluentNavigationTabItemStyle}"
                    TabStripPlacement="Left">
            <TabItem Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Navigation.Operation]}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="18">
                        <TextBlock Style="{StaticResource PageTitleStyle}"
                                   Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Operation.Title]}" />

                        <TextBlock Margin="0,10,0,0"
                                   TextWrapping="Wrap"
                                   Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Operation.Description]}" />

                        <GroupBox Margin="0,22,0,0"
                                  Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Status.Ready]}">
                            <TextBlock Margin="12"
                                       TextWrapping="Wrap"
                                       Text="{Binding StatusMessage}" />
                        </GroupBox>

                        <Separator Margin="0,20,0,20" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <GroupBox Margin="0,0,10,0"
                                      Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Operation.ScaleState]}">
                                <StackPanel Margin="12">
                                    <TextBlock Style="{StaticResource StatePrimaryValueTextStyle}"
                                               Text="{Binding ScaleStateText}" />
                                    <TextBlock Margin="0,18,0,0"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Operation.CurrentResolution]}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Style="{StaticResource StateSecondaryValueTextStyle}"
                                               Text="{Binding CurrentResolutionText}" />
                                    <TextBlock Margin="0,18,0,0"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Operation.TargetResolution]}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Style="{StaticResource StateSecondaryValueTextStyle}"
                                               Text="{Binding TargetResolutionText}" />
                                    <TextBlock Margin="0,18,0,0"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Operation.OriginalResolution]}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Style="{StaticResource StateSecondaryValueTextStyle}"
                                               Text="{Binding OriginalResolutionText}" />
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Grid.Column="1"
                                      Margin="10,0,0,0"
                                      Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Operation.MonitorState]}">
                                <StackPanel Margin="12">
                                    <TextBlock Style="{StaticResource StatePrimaryValueTextStyle}"
                                               Text="{Binding MonitorStateText}" />
                                    <TextBlock Margin="0,18,0,0"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Operation.ActiveProcesses]}" />
                                    <TextBlock Margin="0,6,0,0"
                                               TextWrapping="Wrap"
                                               Text="{Binding ActiveProcessesText}" />
                                    <StackPanel Margin="0,24,0,0"
                                                Orientation="Horizontal">
                                        <Button MinWidth="150"
                                                Command="{Binding StartMonitoringCommand}"
                                                Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Operation.StartButton]}" />
                                        <Button MinWidth="168"
                                                Margin="12,0,0,0"
                                                Command="{Binding StopMonitoringCommand}"
                                                Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Operation.StopButton]}" />
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>
                        </Grid>

                        <Separator Margin="0,20,0,20" />

                        <GroupBox Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Operation.WorkflowTitle]}">
                            <TextBlock Margin="12"
                                       TextWrapping="Wrap"
                                       Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Operation.WorkflowDescription]}" />
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Navigation.Settings]}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="18">
                        <TextBlock Style="{StaticResource PageTitleStyle}"
                                   Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings.Title]}" />

                        <TextBlock Margin="0,10,0,0"
                                   TextWrapping="Wrap"
                                   Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings.Description]}" />

                        <GroupBox Margin="0,22,0,0"
                                  Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings.AutoStartTitle]}">
                            <StackPanel Margin="12">
                                <TextBlock TextWrapping="Wrap"
                                           Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings.AutoStartDescription]}" />
                                <CheckBox Margin="0,12,0,0"
                                          IsChecked="{Binding AutoStartEnabled}"
                                          Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings.AutoStartTitle]}" />
                            </StackPanel>
                        </GroupBox>

                        <Separator Margin="0,20,0,20" />

                        <GroupBox Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings.TargetProgramsTitle]}">
                            <StackPanel Margin="12">
                                <TextBlock TextWrapping="Wrap"
                                           Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings.TargetProgramsDescription]}" />

                                <DockPanel Margin="0,16,0,0"
                                           LastChildFill="False">
                                    <StackPanel DockPanel.Dock="Right"
                                                Orientation="Horizontal">
                                        <Button Width="44"
                                                Height="44"
                                                Command="{Binding RemoveTargetProgramCommand}"
                                                Content="−"
                                                FontSize="18"
                                                Visibility="{Binding SelectedTargetProgram, Converter={StaticResource NullToVisibilityConverter}}" />
                                        <Button Width="44"
                                                Height="44"
                                                Margin="10,0,0,0"
                                                Command="{Binding AddTargetProgramCommand}"
                                                Content="+"
                                                FontSize="18" />
                                    </StackPanel>
                                </DockPanel>

                                <ListBox Margin="0,16,0,0"
                                         MinHeight="180"
                                         ItemsSource="{Binding TargetPrograms}"
                                         SelectedItem="{Binding SelectedTargetProgram}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="28" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Image Width="20"
                                                       Height="20"
                                                       VerticalAlignment="Center"
                                                       Source="{Binding Icon}"
                                                       Stretch="Uniform" />
                                                <TextBlock Grid.Column="1"
                                                           Margin="12,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Text="{Binding ExecutablePath}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </GroupBox>

                        <Separator Margin="0,20,0,20" />

                        <GroupBox Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings.ResolutionTitle]}">
                            <StackPanel Margin="12">
                                <TextBlock TextWrapping="Wrap"
                                           Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings.ResolutionDescription]}" />
                                <TextBlock Margin="0,12,0,0"
                                           TextWrapping="Wrap"
                                           Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings.GpuHint]}" />

                                <Grid Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Style="{StaticResource CaptionTextStyle}"
                                                   Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings.WidthLabel]}" />
                                        <TextBox Margin="0,8,0,0"
                                                 Text="{Binding TargetWidth, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                Margin="10,0,0,0">
                                        <TextBlock Style="{StaticResource CaptionTextStyle}"
                                                   Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings.HeightLabel]}" />
                                        <TextBox Margin="0,8,0,0"
                                                 Text="{Binding TargetHeight, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock Margin="0,18,0,0"
                                           Style="{StaticResource CaptionTextStyle}"
                                           Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings.PresetLabel]}" />
                                <ComboBox x:Name="ResolutionPresetComboBox"
                                          Margin="0,8,0,0"
                                          SelectedIndex="0"
                                          SelectionChanged="ResolutionPresetSelectionChanged">
                                    <ComboBoxItem Tag=""
                                                  Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings.PresetPlaceholder]}" />
                                    <ComboBoxItem Tag="2280x1280"
                                                  Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings.Preset1]}" />
                                    <ComboBoxItem Tag="1707x960"
                                                  Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings.Preset2]}" />
                                    <ComboBoxItem Tag="2027x1140"
                                                  Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings.Preset3]}" />
                                </ComboBox>
                            </StackPanel>
                        </GroupBox>

                        <Separator Margin="0,20,0,20" />

                        <GroupBox Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings.LanguageTitle]}">
                            <StackPanel Margin="12">
                                <TextBlock TextWrapping="Wrap"
                                           Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings.LanguageDescription]}" />
                                <ComboBox Margin="0,16,0,0"
                                          DisplayMemberPath="DisplayName"
                                          ItemsSource="{Binding AvailableLanguages}"
                                          SelectedItem="{Binding SelectedLanguage}" />
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
